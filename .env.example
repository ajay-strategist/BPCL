# Copy this file to ".env" and fill in real values. NEVER commit the real .env.
# These are read by server.js (production) and the Vite dev middleware.

# --- HR portal login (CHANGE THESE before deploying publicly) ---
ADMIN_USER=bpcl_hr
ADMIN_PASS=change-me-to-a-strong-password

# --- Server port (optional) ---
PORT=5000

# --- Default SMTP settings (optional) ---
# Users normally enter SMTP details in the UI, but you can pre-seed them here.
# For Gmail: host=smtp.gmail.com, port=465, secure=true, and PASS = a 16-char App Password.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=BPCL Welcome Team
SMTP_FROM_EMAIL=
